rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Fields: title, slug, content, excerpt, category, thumbnailUrl, authorId, authorName, createdAt, updatedAt, status, viewCount
    //
    // Collection: posts/{postId}/comments
    // Fields: postId, authorId, authorName, content, createdAt
    //
    // Collection: users
    // Fields: email, displayName, photoURL, role, createdAt
    //
    // Collection: newsletter_subscribers
    // Fields: email, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "tobiasrojeancarl@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.slug is string && data.slug.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.status in ['draft', 'published'];
    }

    function isValidComment(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.authorId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && request.resource.data.role == 'reader';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /posts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
      }
    }

    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
